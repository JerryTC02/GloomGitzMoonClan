<?xml version="1.0" encoding="utf-8" ?>

<Defs>

  <ThingDef ParentName="GloomGitzBaseMeleeWeapon_Sharp_Quality">
    <defName>MeleeWeapon_AOSGitz_Knightspear</defName>
    <label>Loonknight Spear</label>
    <techLevel>Medieval</techLevel>
    <description>An oddly ornate spear wielded by Loonknights, its been made to resemble a lance despite often being used by knights who are on foot. While the general design isnt far from a typical Grot spear, the materials and quality still make it a better choice for any aspiring loon to wield.</description>
    <graphicData>
      <texPath>Things/Item/Equipment/Gitz/WeaponMelee/Loons/LoonSpear</texPath>
      <graphicClass>Graphic_Single</graphicClass>
	  <drawSize>1.65</drawSize>
    </graphicData>
    <uiIconScale>1.2</uiIconScale>
    <statBases>
      <WorkToMake>14750</WorkToMake>
      <Mass>2.8</Mass>
    </statBases>
	<equippedStatOffsets>
		<ArmorRating_Sharp>0.03</ArmorRating_Sharp>
	</equippedStatOffsets>
    <equippedAngleOffset>-25</equippedAngleOffset>
	<costList>
      <Steel>80</Steel>
	  <WoodLog>30</WoodLog>
    </costList>
    <weaponTags>
	 <li>GloomGitzLoonKnight</li>
    </weaponTags>
    <tools>
      <li>
        <label>shaft</label>
        <capacities>
          <li>Blunt</li>
          <li>Poke</li>
        </capacities>
        <power>14</power>
        <cooldownTime>2.4</cooldownTime>
      </li>
      <li>
        <label>point</label>
        <capacities>
          <li>Stab</li>
        </capacities>
        <power>26</power>
        <armorPenetration>0.50</armorPenetration>
        <cooldownTime>2.35</cooldownTime>
      </li>
	  <li>
        <label>edge</label>
        <capacities>
          <li>Cut</li>
        </capacities>
        <power>17</power>
        <cooldownTime>2.2</cooldownTime>
      </li>
    </tools>
    <recipeMaker>
      <researchPrerequisite>GloomGitz_Moonclan_Loonboon</researchPrerequisite>
      <skillRequirements>
        <Crafting>6</Crafting>
      </skillRequirements>
	  <recipeUsers Inherit="False">
        <li>AOSgitz_Smithy</li>
      </recipeUsers>
      <displayPriority>6</displayPriority>
    </recipeMaker>
  </ThingDef>
  
  <ThingDef ParentName="GloomGitzBaseMeleeWeapon_Blunt_Quality">
    <defName>MeleeWeapon_AOSGitz_Knighthammer</defName>
    <label>Loonknight Wonky Lance</label>
    <techLevel>Medieval</techLevel>
    <description>Few Loonknights are capable of riding squigs, and even fewer survive such a task, for those that do, trying to aim a proper lance is nearly impossible with a Squigs erratic hopping. The "Wonky Lance" as it was called by Loonknight Grib, is a large wooden mallet made in the style of a lance and works with the movement of a squig to deliver crushing blows.</description>
    <graphicData>
      <texPath>Things/Item/Equipment/Gitz/WeaponMelee/Loons/LoonHammer</texPath>
      <graphicClass>Graphic_Single</graphicClass>
	  <drawSize>1.25</drawSize>
    </graphicData>
    <uiIconScale>1.2</uiIconScale>
    <statBases>
