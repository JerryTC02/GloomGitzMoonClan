<Defs>

  <ThingDef ParentName="GloomGitzBaseMeleeWeapon_Sharp_Quality">
    <defName>MeleeWeapon_AOSGitz_Slitta</defName>
    <label>Slitta</label>
    <techLevel>Medieval</techLevel>
    <description>Salvaged or stolen blades affixed to a stick, Slittas are the worst weapon a Grot could be stuck with. Its only advantage is basically anyone could make one, and it weighs next to nothing.</description>
    <graphicData>
      <texPath>Things/Item/Equipment/Gitz/WeaponMelee/Basic/Slicer</texPath>
      <graphicClass>Graphic_Single</graphicClass>
	  <drawSize>1.35</drawSize>
    </graphicData>
    <uiIconScale>1.2</uiIconScale>
    <statBases>
      <WorkToMake>1500</WorkToMake>
      <Mass>0.20</Mass>
    </statBases>
	<equippedStatOffsets>
	</equippedStatOffsets>
	<equippedAngleOffset>-65</equippedAngleOffset>
	<costList>
      <Steel>25</Steel>
	  <WoodLog>1</WoodLog>
    </costList>
    <weaponTags>
	 <li>GloomGitzMeleeBasic</li>
    </weaponTags>
    <tools>
      <li>
        <label>handle</label>
        <capacities>
          <li>Blunt</li>
        </capacities>
        <power>7</power>
        <cooldownTime>1.8</cooldownTime>
      </li>
      <li>
        <label>blade</label>
        <capacities>
          <li>Cut</li>
        </capacities>
        <power>9</power>
        <cooldownTime>1.3</cooldownTime>
      </li>
      <li>
        <label>point</label>
        <capacities>
          <li>Stab</li>
        </capacities>
        <power>7</power>
        <cooldownTime>1.8</cooldownTime>
      </li>
    </tools>
    <recipeMaker>
      <researchPrerequisite>GloomGitz_Basic</researchPrerequisite>
      <skillRequirements>
        <Crafting>1</Crafting>
      </skillRequirements>
	  <recipeUsers Inherit="False">
        <li>CraftingSpot</li>
		<li>AOSgitz_Smithy</li>
      </recipeUsers>
      <displayPriority>1</displayPriority>
    </recipeMaker>
  </ThingDef>

