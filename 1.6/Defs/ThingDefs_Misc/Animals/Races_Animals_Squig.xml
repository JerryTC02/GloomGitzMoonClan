<?xml version="1.0" encoding="utf-8" ?>

<Defs>

  <ThingDef ParentName="AnimalThingBase">
    <defName>AOSGitz_CaveSquig</defName>
    <label>Cave Squig</label>
    <devNote>Squig</devNote>
    <description>The most common variety of Squig across the realms, a majority of squig breeds descend from the humble Cave Squig. Ravenous and ill tempered, Cave Squigs make for great warbeasts and unreliable but effective mounts.</description>
    <statBases>
      <MoveSpeed>4.7</MoveSpeed>
      <MarketValue>450</MarketValue>
	  <ComfyTemperatureMax>50</ComfyTemperatureMax>
      <ComfyTemperatureMin>-30</ComfyTemperatureMin>
      <FilthRate>1</FilthRate>
      <ArmorRating_Sharp>0.25</ArmorRating_Sharp>
      <ToxicEnvironmentResistance>0.65</ToxicEnvironmentResistance>
	  <MinimumHandlingSkill>6</MinimumHandlingSkill>
      <Wildness>0.65</Wildness>
    </statBases>
	<comps>
      <li Class="CompProperties_EggLayer">
        <eggUnfertilizedDef>AOSGitz_EggSquigFertilized</eggUnfertilizedDef>
        <eggFertilizedDef>AOSGitz_EggSquigFertilized</eggFertilizedDef>
		<eggLayFemaleOnly>false</eggLayFemaleOnly>
        <eggFertilizationCountMax>1</eggFertilizationCountMax>
        <eggLayIntervalDays>10</eggLayIntervalDays>
        <eggCountRange>1</eggCountRange>
      </li>
    </comps>
    <race>
      <body>JTC_BasicSquig</body>
      <predator>true</predator>
	  <disableMating>true</disableMating>
	  <specificMeatDef>Meat_AOSGitz_Squig</specificMeatDef>
	  <hasGenders>false</hasGenders>
      <petness>0.25</petness>
      <baseBodySize>2</baseBodySize>
      <baseHungerRate>0.27</baseHungerRate>
      <baseHealthScale>1.05</baseHealthScale>
      <maxPreyBodySize>2.1</maxPreyBodySize>
      <foodType>OmnivoreAnimal</foodType>
      <leatherDef>Leather_Wolf</leatherDef>
      <gestationPeriodDays>10</gestationPeriodDays>
      <nameOnTameChance>1</nameOnTameChance>
      <trainability>Advanced</trainability>
      <specialTrainables>
        <li MayRequire="Ludeon.RimWorld.Odyssey">AttackTarget</li>
      </specialTrainables>
      <manhunterOnTameFailChance>0.50</manhunterOnTameFailChance>
      <manhunterOnDamageChance>1.00</manhunterOnDamageChance>
	  	<wildBiomes>
				<Underground>0.30</Underground>
				<ColdBog>0.12</ColdBog>
				<TemperateSwamp>0.14</TemperateSwamp>
				<AridShrubland>0.13</AridShrubland>
				<Desert>0.17</Desert>
		</wildBiomes>
      <lifeExpectancy>50</lifeExpectancy>
      <lifeStageAges>
        <li>
          <def>AnimalBaby</def>
          <minAge>0</minAge>
        </li>
        <li>
          <def>AnimalJuvenile</def>
          <minAge>0.1</minAge>
        </li>
        <li>
          <def>AnimalAdult</def>
          <minAge>0.2</minAge>
        </li>
      </lifeStageAges>
      <soundMeleeHitPawn>Pawn_Melee_SmallScratch_HitPawn</soundMeleeHitPawn>
      <soundMeleeHitBuilding>Pawn_Melee_SmallScratch_HitBuilding</soundMeleeHitBuilding>
      <soundMeleeMiss>Pawn_Melee_SmallScratch_Miss</soundMeleeMiss>
      <soundEating>PredatorLarge_Eat</soundEating>
      <headPosPerRotation>
        <li>(0.0, 0, 0.2)</li>
        <li>(0.3, 0, 0.03)</li>
        <li>(0.0, 0, -0.16)</li>
        <li>(-0.3, 0, 0.03)</li>
      </headPosPerRotation>
    </race>
    <tradeTags>
	  <li>GloomGitzSquig</li>
    </tradeTags>
    <tools>
      <li>
        <label>left leg</label>
        <labelNoLocation>claw</labelNoLocation>
        <capacities>
          <li>Scratch</li>
		  <li>Blunt</li>
        </capacities>
        <power>13</power>
        <cooldownTime>1.8</cooldownTime>
        <linkedBodyPartsGroup>FrontLeftPaw</linkedBodyPartsGroup>
        <surpriseAttack>
          <extraMeleeDamages>
            <li>
              <def>Stun</def>
              <amount>13</amount>
            </li>
          </extraMeleeDamages>
        </surpriseAttack>
		<chanceFactor>0.2</chanceFactor>
      </li>
      <li>
        <label>right leg</label>
        <labelNoLocation>claw</labelNoLocation>
        <capacities>
          <li>Scratch</li>
		  <li>Blunt</li>
        </capacities>
        <power>13</power>
        <cooldownTime>1.8</cooldownTime>
        <linkedBodyPartsGroup>FrontRightPaw</linkedBodyPartsGroup>
        <surpriseAttack>
          <extraMeleeDamages>
            <li>
              <def>Stun</def>
              <amount>14</amount>
            </li>
          </extraMeleeDamages>
        </surpriseAttack>
		<chanceFactor>0.2</chanceFactor>
      </li>
      <li>
        <label>large maw</label>
        <capacities>
          <li>Bite</li>
        </capacities>
        <power>18</power>
        <cooldownTime>2.1</cooldownTime>
        <linkedBodyPartsGroup>Teeth</linkedBodyPartsGroup>
        <chanceFactor>0.9</chanceFactor>
        <surpriseAttack>
          <extraMeleeDamages>
            <li>
              <def>Stun</def>
              <amount>14</amount>
            </li>
          </extraMeleeDamages>
        </surpriseAttack>
      </li>
      <li>
        <label>head</label>
        <capacities>
          <li>Blunt</li>
        </capacities>
        <power>13</power>
        <cooldownTime>2.2</cooldownTime>
        <linkedBodyPartsGroup>HeadAttackTool</linkedBodyPartsGroup>
        <ensureLinkedBodyPartsGroupAlwaysUsable>true</ensureLinkedBodyPartsGroupAlwaysUsable>
        <chanceFactor>0.4</chanceFactor>
      </li>
    </tools>
  </ThingDef>
  
