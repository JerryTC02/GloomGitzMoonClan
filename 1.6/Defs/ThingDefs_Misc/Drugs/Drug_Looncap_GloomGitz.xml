<?xml version="1.0" encoding="utf-8" ?>

<Defs>

  <ThingDef ParentName="DrugPillBase">
    <defName>AOSGitz_Looncap</defName>
    <label>Raw Looncap</label>
    <description>Looncaps impart a small portion of Da Bad Moons energy unto the user, granting them effects similar to that of Gloomspite.</description>
    <descriptionHyperlinks>
      <HediffDef>AOSGitz_LoonCap_High</HediffDef>
      <HediffDef>AOSGitz_Looncap_Addiction</HediffDef>
    </descriptionHyperlinks>
    <graphicData>
      <texPath>Things/Item/Resource/Gitz/LooncapDrug</texPath>
      <graphicClass>Graphic_StackCount</graphicClass>
    </graphicData>
    <rotatable>false</rotatable>
    <statBases>
      <MarketValue>50</MarketValue>
      <Mass>0.01</Mass>
    </statBases>
    <techLevel>Medieval</techLevel>
    <ingestible>
      <drugCategory>Medical</drugCategory>
      <outcomeDoers>
        <li Class="IngestionOutcomeDoer_GiveHediff">
          <hediffDef>AOSGitz_LoonCap_High</hediffDef>
          <severity>1.00</severity>
          <doToGeneratedPawnIfAddicted>true</doToGeneratedPawnIfAddicted>
        </li>
      </outcomeDoers>
    </ingestible>
    <comps>
      <li Class="CompProperties_Drug">
        <chemical>AOSGitz_Loon</chemical>
        <addictiveness>1.00</addictiveness>
        <needLevelOffset>0.9</needLevelOffset>
        <listOrder>1010</listOrder>
      </li>
    </comps>
    <tradeTags>
      <li>GloomGitzNeverEver</li>
    </tradeTags>
    <allowedArchonexusCount>50</allowedArchonexusCount>
  </ThingDef>

  <HediffDef>
    <defName>AOSGitz_LoonCap_High</defName>
    <hediffClass>Hediff_High</hediffClass>
    <label>looncap gloomspite</label>
    <description>Active Gloomspite magic in the body, improving a Grots power in every way imaginable.</description>
    <defaultLabelColor>(1,1,0.5)</defaultLabelColor>
    <scenarioCanAdd>true</scenarioCanAdd>
    <maxSeverity>1.0</maxSeverity>
    <isBad>false</isBad>
    <comps>
      <li Class="HediffCompProperties_HealPermanentWounds" />
    </comps>
    <stages>
      <li>
        <painFactor>0.9</painFactor>
        <capMods>
          <li>
            <capacity>Consciousness</capacity>
            <offset>0.05</offset>
          </li>
          <li>
            <capacity>Moving</capacity>
            <offset>0.03</offset>
          </li>
          <li>
            <capacity>Sight</capacity>
            <offset>0.10</offset>
          </li>
          <li>
            <capacity>BloodFiltration</capacity>
            <offset>0.35</offset>
          </li>
          <li>
            <capacity>BloodPumping</capacity>
            <offset>0.10</offset>
          </li>
           <li>
            <capacity>Metabolism</capacity>
            <offset>0.10</offset>
          </li>
          <li>
            <capacity>Breathing</capacity>
            <offset>0.05</offset>
          </li>
        </capMods>
      </li>
    </stages>
  </HediffDef>

  <ChemicalDef>
    <defName>AOSGitz_Loon</defName>
    <label>Looncap</label>
    <addictionHediff>AOSGitz_Looncap_Addiction</addictionHediff>
    <canBinge>false</canBinge>
    <generateAddictionGenes>false</generateAddictionGenes>
  </ChemicalDef>

  <NeedDef ParentName="DrugAddictionNeedBase">
    <defName>Chemical_AOSGitz_Looncap</defName>
    <needClass>Need_Chemical</needClass>
    <label>looncap</label>
    <description>This person's body is enhanced by gloomspite magic.\n\nWithout regular doses of looncaps, the blessing will become a curse. If this happens, the user becomes continuously, violently insane and eventually dies.\n\nThis addiction never goes away.</description>
    <listPriority>45</listPriority>
    <fallPerDay>0.15</fallPerDay>
    <developmentalStageFilter>Baby, Child, Adult</developmentalStageFilter>
  </NeedDef>

  <HediffDef ParentName="AddictionBase">
    <defName>AOSGitz_Looncap_Addiction</defName>
    <label>looncap need</label>
    <description>Gloomspite magic in the body. Gloomspite grows wild over time; only regular doses of fresh looncaps can prevent this process.\nWithout looncaps, the blessing will become a curse, causing the victim to go insane and die.</description>
    <hediffClass>Hediff_Addiction</hediffClass>
    <chemicalNeed>Chemical_AOSGitz_Looncap</chemicalNeed>
    <everCurableByItem>false</everCurableByItem>
    <stages>
      <li>
      </li>
      <li>
        <label>unmet</label>
        <painOffset>0.4</painOffset>
        <lifeThreatening>true</lifeThreatening>
        <deathMtbDays>7</deathMtbDays>
        <mtbDeathDestroysBrain>true</mtbDeathDestroysBrain>
        <capMods>
          <li>
            <capacity>Consciousness</capacity>
            <setMax>0.8</setMax>
          </li>
        </capMods>
        <mentalStateGivers>
          <li>
            <mentalState>Berserk</mentalState>
            <mtbDays>0.1</mtbDays>
          </li>
        </mentalStateGivers>
      </li>
    </stages>
  </HediffDef>

</Defs>
