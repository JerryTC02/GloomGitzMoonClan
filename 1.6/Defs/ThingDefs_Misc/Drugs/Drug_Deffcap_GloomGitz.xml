<?xml version="1.0" encoding="utf-8" ?>

<Defs>

  <ThingDef ParentName="MakeableDrugBase">
    <defName>AOSGitz_DriedDeffcapDrug</defName>
    <label>Dried Deffcap</label>
    <description>Cooked and preserved Deffcap Mushrooms, mostly used by underlings of Shamans or as a backup source of the drug when fresh Deffcaps are unavailable.</description>
    <descriptionHyperlinks>
      <HediffDef>AOSGitz_DeffcapHigh</HediffDef>
      <HediffDef>AOSGitz_DeffcapTolerance</HediffDef>
      <HediffDef>AOSGitz_DeffcapAddiction</HediffDef>
    </descriptionHyperlinks>
    <graphicData>
      <texPath>Things/Item/Resource/Gitz/DriedDefcap/DriedDefcap_a</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>0.75</drawSize>
    </graphicData>
    <rotatable>false</rotatable>
    <statBases>
      <WorkToMake>525</WorkToMake>
      <MarketValue>10</MarketValue>
      <Mass>0.025</Mass>
    </statBases>
    <techLevel>Medieval</techLevel>
    <ingestible>
      <foodType>Processed</foodType>
      <joyKind>Chemical</joyKind>
      <joy>0.65</joy>
      <baseIngestTicks>125</baseIngestTicks>
      <nurseable>true</nurseable>
      <drugCategory>Hard</drugCategory>
      <ingestEffectEat>EatVegetarian</ingestEffectEat>
      <ingestHoldOffsetStanding>
        <northDefault>
          <offset>(0.23,0,0.065)</offset>
        </northDefault>
      </ingestHoldOffsetStanding>
      <ingestHoldUsesTable>false</ingestHoldUsesTable>
      <useEatingSpeedStat>true</useEatingSpeedStat>
      <outcomeDoers>
        <li Class="IngestionOutcomeDoer_GiveHediff">
          <hediffDef>AOSGitz_DeffcapHigh</hediffDef>
          <severity>0.75</severity>
          <toleranceChemical>AOSGitz_Deff</toleranceChemical>
        </li>
        <li Class="IngestionOutcomeDoer_OffsetNeed">
          <need>Rest</need>
          <offset>0.15</offset>
          <toleranceChemical>AOSGitz_Deff</toleranceChemical>
        </li>
        <li Class="IngestionOutcomeDoer_GiveHediff">
          <hediffDef>AOSGitz_DeffcapTolerance</hediffDef>
          <toleranceChemical>AOSGitz_Deff</toleranceChemical>
          <severity>0.03</severity>
          <divideByBodySize>true</divideByBodySize>
          <multiplyByGeneToleranceFactors>true</multiplyByGeneToleranceFactors>
        </li>
		<li Class="IngestionOutcomeDoer_OffsetPsyfocus">
          <offset>0.05</offset>
        </li>
      </outcomeDoers>
    </ingestible>
    <recipeMaker>
      <researchPrerequisite>GloomGitz_Moonclan_Plants</researchPrerequisite>
      <recipeUsers>
        <li>AOSgitz_Drugbench</li>
		<li>Campfire</li>
      </recipeUsers>
      <soundWorking>Recipe_Drug</soundWorking>
      <displayPriority>2</displayPriority>
    </recipeMaker>
    <costList>
      <AOSGitz_Rawdeffcap>3</AOSGitz_Rawdeffcap>
    </costList>
    <comps>
      <li Class="CompProperties_Drug">
        <chemical>AOSGitz_Deff</chemical>
        <addictiveness>0.08</addictiveness>
		<minToleranceToAddict>0.15</minToleranceToAddict>
        <existingAddictionSeverityOffset>0.30</existingAddictionSeverityOffset>
        <needLevelOffset>0.9</needLevelOffset>
        <listOrder>110</listOrder>
        <overdoseSeverityOffset>0.20~0.35</overdoseSeverityOffset>
        <largeOverdoseChance>0.015</largeOverdoseChance>
      </li>
    </comps>
  </ThingDef>
  
  <HediffDef>
    <defName>AOSGitz_DeffcapHigh</defName>
    <label>high on deffcap</label>
    <labelNoun>a deffcap high</labelNoun>
    <description>Active deffcap spores in the brain. Generates an erratic and maddening but possibly prophetic high.</description>
    <hediffClass>Hediff_High</hediffClass>
    <defaultLabelColor>(1,0,0.5)</defaultLabelColor>
    <scenarioCanAdd>true</scenarioCanAdd>
    <maxSeverity>1.0</maxSeverity>
    <isBad>false</isBad>
    <comps>
      <li Class="HediffCompProperties_SeverityPerDay">
        <severityPerDay>-3.5</severityPerDay>
        <showHoursToRecover>true</showHoursToRecover>
      </li>
    </comps>
      <stages>
        <li>
          <painFactor>0.85</painFactor>
          <statFactors>
            <RestFallRateFactor>0.75</RestFallRateFactor>
	        <ResearchSpeed>1.15</ResearchSpeed>
			<MoveSpeed>1.10</MoveSpeed>
          </statFactors>
        </li>
      </stages>
  </HediffDef>
  
  <ThoughtDef>
    <defName>AOSGitz_DriedDeffcapHigh</defName>
    <workerClass>ThoughtWorker_Hediff</workerClass>
    <hediff>AOSGitz_DeffcapHigh</hediff>
    <validWhileDespawned>true</validWhileDespawned>
    <developmentalStageFilter>Baby, Child, Adult</developmentalStageFilter>
    <stages>
      <li>
        <label>high on dried deffcap</label>
        <description>Da Bad Moon is showing me fings.</description>
        <baseMoodEffect>25</baseMoodEffect>
      </li>
    </stages>
  </ThoughtDef>
  
  <ThingDef ParentName="MakeableDrugBase">
    <defName>AOSGitz_DeffcapPotion</defName>
    <label>Deffcap Brew</label>
    <description>A noxious concotion of distilled Deffcaps, made to grant Grot Shamans the ability to divine the future more clearly and work themselves into a vicious crazed battle-madness.</description>
    <descriptionHyperlinks>
      <HediffDef>AOSGitz_DeffcapPotionHigh</HediffDef>
      <HediffDef>AOSGitz_DeffcapTolerance</HediffDef>
      <HediffDef>AOSGitz_DeffcapAddiction</HediffDef>
    </descriptionHyperlinks>
    <graphicData>
      <texPath>Things/Item/Resource/Gitz/DefcapPotion</texPath>
      <graphicClass>Graphic_StackCount</graphicClass>
    </graphicData>
    <rotatable>false</rotatable>
    <statBases>
      <WorkToMake>900</WorkToMake>
      <MarketValue>46</MarketValue>
      <Mass>0.12</Mass>
    </statBases>
    <techLevel>Medieval</techLevel>
    <ingestible>
      <joyKind>Chemical</joyKind>
      <joy>0.50</joy>
      <drugCategory>Hard</drugCategory>
      <foodType>Processed, Fluid</foodType>
      <baseIngestTicks>65</baseIngestTicks>
      <ingestSound>Ingest_Beer</ingestSound>
      <ingestHoldOffsetStanding>
        <northDefault>
          <offset>(0.18,0,0)</offset>
        </northDefault>
      </ingestHoldOffsetStanding>
      <ingestCommandString>Drink {0}</ingestCommandString>
      <ingestReportString>Drinking {0}.</ingestReportString>
      <useEatingSpeedStat>true</useEatingSpeedStat>
      <chairSearchRadius>0</chairSearchRadius>
      <outcomeDoers>
        <li Class="IngestionOutcomeDoer_GiveHediff">
          <hediffDef>AOSGitz_DeffcapPotionHigh</hediffDef>
          <severity>0.5</severity>
          <toleranceChemical>AOSGitz_Deff</toleranceChemical>
        </li>
		<li Class="IngestionOutcomeDoer_GiveHediff">
          <hediffDef>AOSGitz_DeffcapTolerance</hediffDef>
          <toleranceChemical>AOSGitz_Deff</toleranceChemical>
          <severity>0.06</severity>
          <divideByBodySize>true</divideByBodySize>
          <multiplyByGeneToleranceFactors>true</multiplyByGeneToleranceFactors>
        </li>
        <li Class="IngestionOutcomeDoer_OffsetNeed">
          <need>Rest</need>
          <offset>0.25</offset>
          <toleranceChemical>AOSGitz_Deff</toleranceChemical>
        </li>
        <li Class="IngestionOutcomeDoer_OffsetPsyfocus">
          <offset>0.23</offset>
        </li>
      </outcomeDoers>
    </ingestible>
    <recipeMaker>
      <researchPrerequisite>GloomGitz_Moonclan_Drugs</researchPrerequisite>
      <recipeUsers>
        <li>AOSgitz_Drugbench</li>
      </recipeUsers>
      <soundWorking>Recipe_Drug</soundWorking>
      <displayPriority>3</displayPriority>
    </recipeMaker>
    <costList>
      <AOSGitz_Rawdeffcap>12</AOSGitz_Rawdeffcap>
    </costList>
    <comps>
      <li Class="CompProperties_Drug">
        <chemical>AOSGitz_Deff</chemical>
        <addictiveness>0.08</addictiveness>
		<minToleranceToAddict>0.15</minToleranceToAddict>
        <existingAddictionSeverityOffset>0.20</existingAddictionSeverityOffset>
        <needLevelOffset>0.9</needLevelOffset>
        <isCombatEnhancingDrug>true</isCombatEnhancingDrug>
        <listOrder>200</listOrder>
        <overdoseSeverityOffset>0.18~0.35</overdoseSeverityOffset>
        <largeOverdoseChance>0.02</largeOverdoseChance>
      </li>
    </comps>
  </ThingDef>
  
  <HediffDef>
    <defName>AOSGitz_DeffcapPotionHigh</defName>
    <hediffClass>Hediff_High</hediffClass>
    <label>high on concentrated deffcap</label>
    <labelNoun>a deffcap high</labelNoun>
    <description>A high concentration of Deffcap spores in the brain. Generates an extremely erratic and maddening but likely prophetic high.</description>
    <defaultLabelColor>(1,0,0.5)</defaultLabelColor>
    <scenarioCanAdd>false</scenarioCanAdd>
    <maxSeverity>1.0</maxSeverity>
    <isBad>false</isBad>
    <comps>
      <li Class="HediffCompProperties_SeverityPerDay">
        <severityPerDay>-1.75</severityPerDay>
        <showHoursToRecover>true</showHoursToRecover>
      </li>
    </comps>
      <stages>
        <li>
          <painFactor>0.75</painFactor>
		  <statFactors>
            <RestFallRateFactor>0.75</RestFallRateFactor>
	        <ResearchSpeed>1.25</ResearchSpeed>
          </statFactors>
          <capMods>
            <li>
              <capacity>Consciousness</capacity>
              <offset>0.35</offset>
            </li>
            <li>
              <capacity>Sight</capacity>
              <offset>0.50</offset>
            </li>
            <li>
              <capacity>Moving</capacity>
              <offset>0.15</offset>
            </li>
          </capMods>
        </li>
      </stages>
  </HediffDef>
  
  <ThoughtDef>
    <defName>AOSGitz_DeffcapPotionHigh</defName>
    <workerClass>ThoughtWorker_Hediff</workerClass>
    <hediff>AOSGitz_DeffcapPotionHigh</hediff>
    <validWhileDespawned>true</validWhileDespawned>
    <developmentalStageFilter>Baby, Child, Adult</developmentalStageFilter>
    <stages>
      <li>
        <label>high on deffcap brew</label>
        <description>Da Bad Moon is showing me MANY fings, WONDERFUL fings.</description>
        <baseMoodEffect>12</baseMoodEffect>
      </li>
    </stages>
  </ThoughtDef>
  
  <ChemicalDef>
    <defName>AOSGitz_Deff</defName>
    <label>deffcap spores</label>
    <addictionHediff>AOSGitz_DeffcapAddiction</addictionHediff>
    <toleranceHediff>AOSGitz_DeffcapTolerance</toleranceHediff>
    <onGeneratedAddictedToleranceChance>0.8</onGeneratedAddictedToleranceChance>
    <onGeneratedAddictedEvents>
      <li>
        <hediff>ChemicalDamageModerate</hediff>
        <chance>0.02</chance>
        <partsToAffect>
          <li>Brain</li>
        </partsToAffect>
      </li>
    </onGeneratedAddictedEvents>
    <geneToleranceBuildupFactorResist>0.5</geneToleranceBuildupFactorResist>
    <geneToleranceBuildupFactorImmune>0</geneToleranceBuildupFactorImmune>
    <geneOverdoseChanceFactorResist>0.5</geneOverdoseChanceFactorResist>
    <geneOverdoseChanceFactorImmune>0</geneOverdoseChanceFactorImmune>
  </ChemicalDef>
  
  <NeedDef ParentName="DrugAddictionNeedBase">
    <defName>Chemical_AOSGitz_Deffcap</defName>
    <needClass>Need_Chemical</needClass>
    <label>deff spores</label>
    <description>Because of a deffcap addiction, this person needs to regularly consume the drug to avoid withdrawal symptoms.</description>
    <listPriority>50</listPriority>
  </NeedDef>

  <HediffDef ParentName="DrugToleranceBase">
    <defName>AOSGitz_DeffcapTolerance</defName>
    <label>deffcap tolerance</label>
    <description>A built-up tolerance to deffcap spores. The more severe this tolerance is, the more deffcap-based drugs it takes to get the same effect.</description>
    <comps>
      <li Class="HediffCompProperties_SeverityPerDay">
        <severityPerDay>-0.012</severityPerDay>
      </li>
      <li Class="HediffCompProperties_DrugEffectFactor">
        <chemical>AOSGitz_Deff</chemical>
      </li>
    </comps>
    <hediffGivers>
      <li Class="HediffGiver_RandomDrugEffect">
        <hediff>ChemicalDamageSevere</hediff>
        <severityToMtbDaysCurve>
          <points>
            <li>(0.45, 99999)</li>
            <li>(0.5, 180)</li>
            <li>(1, 135)</li>
          </points>
        </severityToMtbDaysCurve>
        <partsToAffect>
          <li>Kidney</li>
        </partsToAffect>
      </li>
    </hediffGivers>
  </HediffDef>
  
  <HediffDef ParentName="AddictionBase">
    <defName>AOSGitz_DeffcapAddiction</defName>
    <label>deffcap addiction</label>
    <description>A chemical addiction to deffcaps. Long-term consumption of deffcaps has caused a buildup of deffcap spores in the brain, so the brain can no longer function properly without the spores.\n\nWithout regular doses of spores, withdrawal symptoms will begin. However, extended abstinence will allow the body to clear the spores out to an acceptable level, resolving the addiction.</description>
    <hediffClass>Hediff_Addiction</hediffClass>
    <chemicalNeed>Chemical_AOSGitz_Deffcap</chemicalNeed>
    <comps>
      <li Class="HediffCompProperties_SeverityPerDay">
        <severityPerDay>-0.0333</severityPerDay>
        <showDaysToRecover>true</showDaysToRecover>
      </li>
    </comps>
    <stages>
      <li>
      </li>
      <li>
        <label>withdrawal</label>
        <socialFightChanceFactor>3.5</socialFightChanceFactor>
        <statOffsets>
          <RestFallRateFactor>0.45</RestFallRateFactor>
        </statOffsets>
        <capMods>
          <li>
            <capacity>Consciousness</capacity>
            <offset>-0.25</offset>
          </li>
          <li>
            <capacity>Moving</capacity>
            <offset>-0.10</offset>
          </li>
          <li>
            <capacity>Manipulation</capacity>
            <offset>-0.25</offset>
          </li>
        </capMods>
        <mentalStateGivers>
          <li>
            <mentalState>Binging_DrugExtreme</mentalState>
            <mtbDays>40</mtbDays>
          </li>
          <li>
            <mentalState>Wander_Psychotic</mentalState>
            <mtbDays>10</mtbDays>
          </li>
        </mentalStateGivers>
      </li>
    </stages>
  </HediffDef>

  <ThoughtDef>
    <defName>AOSGitz_DeffcapWithdrawal</defName>
    <workerClass>ThoughtWorker_Hediff</workerClass>
    <hediff>AOSGitz_DeffcapAddiction</hediff>
    <validWhileDespawned>true</validWhileDespawned>
    <developmentalStageFilter>Baby, Child, Adult</developmentalStageFilter>
    <stages>
      <li>
        <visible>false</visible>
      </li>
      <li>
        <label>deffcap withdrawal</label>
        <description>I need to see, i must see again!</description>
        <baseMoodEffect>-40</baseMoodEffect>
      </li>
    </stages>
  </ThoughtDef>

</Defs>
