<Defs>

  <GeneCategoryDef>
    <defName>AOSGitz_Grots</defName>
    <label>Grots</label>
    <displayPriorityInXenotype>1006996</displayPriorityInXenotype>
  </GeneCategoryDef>
  
  <GeneDef Name="AOSGitzGenes" Abstract="True">
    <displayCategory>AOSGitz_Grots</displayCategory>
  </GeneDef>

  <GeneDef ParentName="AOSGitzGenes">
    <defName>AOSGitz_MainGene</defName>
    <label>Grot Biology</label>
    <description>Grots are quite pathetic creatures, especially when young they tend to be easy to bruise.</description>
    <iconPath>UI/Icons/AOSGitz_Gene_GrotHead</iconPath>
    <displayOrderInCategory>1</displayOrderInCategory>
	<forcedTraits>
      <li>
        <def>Bloodlust</def>
      </li>
    </forcedTraits>
	<painFactor>1.25</painFactor>
    <biostatMet>0</biostatMet>
    <biostatCpx>5</biostatCpx>
	<missingGeneRomanceChanceFactor>0.2</missingGeneRomanceChanceFactor>
	<exclusionTags>
      <li>Fur</li>
    </exclusionTags>
	<statFactors>
	  <SM_BodySizeMultiplier>0.60</SM_BodySizeMultiplier>
    </statFactors>
	<damageFactors>
      <Flame>1.10</Flame>
    </damageFactors>
	<statOffsets>
	  <MoveSpeed>0.1</MoveSpeed>
    </statOffsets>
    <statFactors>
	  <Fertility>0</Fertility>
    </statFactors>
    <skinIsHairColor>false</skinIsHairColor>
		<renderNodeProperties Inherit="False">
			<li Class="BigAndSmall.PawnComplexRenderingProps">
				<useSkinShader>true</useSkinShader>
			</li>
		</renderNodeProperties>
	<modExtensions>
      <li Class="BigAndSmall.PawnExtension">
	        <headDrawData>
			     <dataSouth>
                    <offset>(0.0, 0., -0.05)</offset>
                </dataSouth>
                <dataWest>
                    <offset>(-0.05, 0.0, -0.05)</offset>
                </dataWest>
                <dataEast>
                    <offset>(0.05, 0.0, -0.05)</offset>
                </dataEast>
                <dataNorth>
                    <offset>(-0.0, 0.0, -0.05)</offset>
                </dataNorth>
			</headDrawData>
	  		<headPaths>
				<Female>Things/Pawn/Humanlike/Heads/Male/goblinhead</Female>
				<Male>Things/Pawn/Humanlike/Heads/Male/goblinhead</Male>
			</headPaths>
			<headMaterial>
				<shader>CutoutComplex</shader>
				<overrideDesiccated>true</overrideDesiccated>
			</headMaterial>
      </li>
    </modExtensions>
  </GeneDef>
  
