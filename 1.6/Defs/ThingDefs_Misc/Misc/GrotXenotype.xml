  <GeneDef ParentName="AOSGitzGenes">
    <defName>AOSGitz_FungalMeat</defName>
    <label>Fungoid Biology</label>
    <description>Greenskins, whether they be Orruk, Grot, or Hobgrot are all infact closer related to mushrooms and fungi then they are most other animals.</description>
    <iconPath>UI/Icons/Gene_FungalGrowth</iconPath>
    <displayOrderInCategory>1</displayOrderInCategory>
    <biostatMet>0</biostatMet>
    <biostatCpx>5</biostatCpx>
	<exclusionTags>
    </exclusionTags>
	<modExtensions>
      <li Class="BigAndSmall.PawnExtension">
        <meatOverride>Meat_AOSGitz_Grot</meatOverride>
      </li>
    </modExtensions>
  </GeneDef>
  
  <ThingDef>
    <defName>Meat_AOSGitz_Grot</defName>
    <label>greenskin flesh</label>
    <description>Tasting closer to a mushroom then human flesh, most races will find the meat of Greenskins acceptable albeit often still do not enjoy the process of butchering the owner to obtain it.</description>
    <thingClass>ThingWithComps</thingClass>
    <selectable>true</selectable>
    <category>Item</category>
    <drawerType>MapMeshOnly</drawerType>
    <tickerType>Rare</tickerType>
    <rotatable>false</rotatable>
    <altitudeLayer>Item</altitudeLayer>
    <resourceReadoutPriority>Middle</resourceReadoutPriority>
    <drawGUIOverlay>true</drawGUIOverlay>
    <healthAffectsPrice>false</healthAffectsPrice>
    <stackLimit>75</stackLimit>
    <alwaysHaulable>true</alwaysHaulable>
    <socialPropernessMatters>true</socialPropernessMatters>
    <tradeability>Sellable</tradeability>
    <pathCost>14</pathCost>
    <statBases>
      <MaxHitPoints>60</MaxHitPoints>
      <Beauty>-3</Beauty>
      <DeteriorationRate>3</DeteriorationRate>
      <Mass>0.03</Mass>
      <Flammability>0.65</Flammability>
      <Nutrition>0.05</Nutrition>
      <FoodPoisonChanceFixedHuman>0.05</FoodPoisonChanceFixedHuman>
      <MarketValue>2</MarketValue>
    </statBases>
    <graphicData>
      <texPath>Things/Item/Resource/Gitz/GrotFlesh</texPath>
      <graphicClass>Graphic_StackCount</graphicClass>
    </graphicData>
    <thingCategories>
      <li>MeatRaw</li>
    </thingCategories>
    <ingredient>
    </ingredient>
    <ingestible>
      <foodType>Meat</foodType>
      <preferability>RawBad</preferability>
      <ingestEffect>EatMeat</ingestEffect>
      <ingestSound>RawMeat_Eat</ingestSound>
    </ingestible>
    <comps>
      <li Class="CompProperties_Forbiddable" />
      <li Class="CompProperties_Rottable">
        <daysToRotStart>5</daysToRotStart>
        <rotDestroys>true</rotDestroys>
      </li>
      <li>
        <compClass>CompHarbingerTreeConsumable</compClass>
      </li>
    </comps>
  </ThingDef>

  <XenotypeDef>
    <defName>AOSGitz_Grot</defName>
    <label>Grot</label>
    <description>Small and runty cousins to the Orruks, Grots are sadistic and cowardly creatures who fear the light of the sun. Grots infest every region that the other known races either cannot or will not inhabit, and begin to spread their spores around it to ensure they will forever hold claim over the area.</description>
