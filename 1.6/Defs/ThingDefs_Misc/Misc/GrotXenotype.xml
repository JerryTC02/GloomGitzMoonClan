    <chanceToUseNameMaker>1</chanceToUseNameMaker>
    <genes>
	  <li>AOSGitz_MainGene</li>
	  <li>AOSGitz_FungalMeat</li>
	  <li>Ageless</li>
	  <li>DarkVision</li>
