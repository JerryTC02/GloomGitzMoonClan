            <growthDurationDays>9</growthDurationDays>
            <requiredMaterials>
             <Meat_AOSGitz_Squig>800</Meat_AOSGitz_Squig>
            </requiredMaterials>
			<pawnKindDescription>The biggest and meanest Grots in a Lurklair, commanding several bosses and the gitz who follow them.</pawnKindDescription>
			<backstoryFilters>
               <li>
                  <categories>
                   <li>GloomGitzSpore</li>
                   <li>GloomGitzBigBoss</li>
                  </categories>
               </li>
            </backstoryFilters>
            <passionChances>
               <li>
                  <skillDef>Shooting</skillDef>
