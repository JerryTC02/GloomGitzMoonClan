                  <chance>1</chance>
               </li>
               <li>
                  <skillDef>Melee</skillDef>
                  <passion>Major</passion>
                  <chance>1</chance>
               </li>
            </passionChances>
			<allowedBuildings>
               <li>AOSGitz_LoonShrine</li>
            </allowedBuildings>
		    <requiredResearch>
               <li>GloomGitz_Moonclan_VeryAdvanced</li>
            </requiredResearch>
            <spawnWithEquipment>false</spawnWithEquipment>
         </li>
    </modExtensions>
  </PawnKindDef>

</Defs>
