<?xml version="1.0" encoding="utf-8" ?>

<Defs>

  <PawnKindDef>
    <defName>AOSGitz_GrotSpawn</defName>
    <label>Grot</label>
    <race>Human</race>
	<nameMaker>NamerGloomGitzPerson</nameMaker>
    <combatPower>30</combatPower>
    <backstoryFiltersOverride>
      <li>
        <categories>
                <li>GloomGitzSpore</li>
                <li>GloomGitzBasic</li>
        </categories>
      </li>
    </backstoryFiltersOverride>
    <minGenerationAge>21</minGenerationAge>
    <maxGenerationAge>22</maxGenerationAge>
    <initialWillRange>5~8</initialWillRange>
    <initialResistanceRange>10~20</initialResistanceRange>
	<isFighter>false</isFighter>
    <fixedGender>Male</fixedGender>
	<xenotypeSet>
      <xenotypeChances>
	   <AOSGitz_Grot>1</AOSGitz_Grot>
      </xenotypeChances>
    </xenotypeSet>
	<skills>
    </skills>
	<modExtensions>
     <li Class="CloneVat.GrowthVatPawnKindDefExtension">
            <growthDurationDays>1.5</growthDurationDays>
            <requiredMaterials>
             <Meat_AOSGitz_Squig>75</Meat_AOSGitz_Squig>
            </requiredMaterials>
			<pawnKindDescription>Young Grots who've only recently emerged from the ground, not likely to live very long.</pawnKindDescription>
			<backstoryFilters>
               <li>
                  <categories>
                   <li>GloomGitzSpore</li>
                   <li>GloomGitzBasic</li>
                  </categories>
               </li>
            </backstoryFilters>
            <passionChances>
               <li>
                  <skillDef>Shooting</skillDef>
                  <passion>Minor</passion>
                  <chance>0.5</chance>
               </li>
               <li>
                  <skillDef>Melee</skillDef>
                  <passion>Minor</passion>
                  <chance>0.5</chance>
               </li>
            </passionChances>
			<allowedBuildings>
               <li>AOSGitz_LoonShrine</li>
            </allowedBuildings>
		    <requiredResearch>
               <li>GloomGitz_Basic</li>
            </requiredResearch>
            <spawnWithEquipment>false</spawnWithEquipment>
         </li>
    </modExtensions>
  </PawnKindDef>
  
  <PawnKindDef>
    <defName>AOSGitz_GrotBossSpawn</defName>
    <label>Grot Boss</label>
    <race>Human</race>
	<nameMaker>NamerGloomGitzPerson</nameMaker>
    <combatPower>30</combatPower>
    <backstoryFiltersOverride>
      <li>
        <categories>
                <li>GloomGitzSpore</li>
                <li>GloomGitzBoss</li>
        </categories>
      </li>
    </backstoryFiltersOverride>
    <minGenerationAge>21</minGenerationAge>
    <maxGenerationAge>22</maxGenerationAge>
    <initialWillRange>5~8</initialWillRange>
    <initialResistanceRange>10~20</initialResistanceRange>
	<isFighter>false</isFighter>
    <fixedGender>Male</fixedGender>
	<xenotypeSet>
      <xenotypeChances>
	   <AOSGitz_BossGrot>1</AOSGitz_BossGrot>
      </xenotypeChances>
    </xenotypeSet>
	<skills>
    </skills>
	<modExtensions>
     <li Class="CloneVat.GrowthVatPawnKindDefExtension">
            <growthDurationDays>6</growthDurationDays>
            <requiredMaterials>
             <Meat_AOSGitz_Squig>300</Meat_AOSGitz_Squig>
            </requiredMaterials>
			<pawnKindDescription>Larger Grots who've bullied a few gitz into listening to them.</pawnKindDescription>
			<backstoryFilters>
               <li>
                  <categories>
                   <li>GloomGitzSpore</li>
                   <li>GloomGitzBoss</li>
                  </categories>
               </li>
            </backstoryFilters>
            <passionChances>
               <li>
                  <skillDef>Shooting</skillDef>
                  <passion>Minor</passion>
                  <chance>0.5</chance>
               </li>
               <li>
                  <skillDef>Melee</skillDef>
                  <passion>Major</passion>
                  <chance>1</chance>
               </li>
            </passionChances>
			<allowedBuildings>
               <li>AOSGitz_LoonShrine</li>
            </allowedBuildings>
		    <requiredResearch>
               <li>GloomGitz_Moonclan_Advanced</li>
            </requiredResearch>
            <spawnWithEquipment>false</spawnWithEquipment>
         </li>
    </modExtensions>
  </PawnKindDef>
  
  <PawnKindDef>
    <defName>AOSGitz_GrotLoonBossSpawn</defName>
    <label>Loon Boss</label>
    <race>Human</race>
	<nameMaker>NamerGloomGitzPerson</nameMaker>
    <combatPower>30</combatPower>
