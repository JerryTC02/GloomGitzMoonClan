      <texPath>Things/Building/Production/Gitz/Campfire/CookingPot_Lit</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawRotated>false</drawRotated>
      <allowFlip>false</allowFlip>
      <damageData>
        <rect>(0.2,0,0.6,0.1)</rect>
      </damageData>
      <drawSize>(1.8,1.8)</drawSize>
      <shaderType>CutoutComplex</shaderType>
      <damageData>
        <cornerTL>Damage/Corner</cornerTL>
        <cornerTR>Damage/Corner</cornerTR>
        <cornerBL>Damage/Corner</cornerBL>
        <cornerBR>Damage/Corner</cornerBR>
      </damageData>
    </graphicData>
	<uiIconScale>0.65</uiIconScale>
	<costList>
      <Steel>30</Steel>
	  <WoodLog>25</WoodLog>
    </costList>
    <castEdgeShadows>true</castEdgeShadows>
    <altitudeLayer>Building</altitudeLayer>
    <fillPercent>0.5</fillPercent>
    <useHitPoints>True</useHitPoints>
    <statBases>
      <WorkToBuild>700</WorkToBuild>
      <MaxHitPoints>190</MaxHitPoints>
      <Flammability>0</Flammability>
      <WorkTableWorkSpeedFactor>0.90</WorkTableWorkSpeedFactor>
	  <Cleanliness>-2</Cleanliness>
    </statBases>
    <size>(1,1)</size>
    <recipes>
      <li>CookMealSimple</li>
      <li>CookMealSimpleBulk</li>
      <li>Make_Pemmican</li>
      <li>Make_PemmicanBulk</li>
	  <li>AOSGitzCookMealBulk_Meat</li>
	  <li>AOSGitzCookMealBulk_Veg</li>
      <li MayRequire="Ludeon.RimWorld.Biotech">Make_BabyFood</li>
      <li MayRequire="Ludeon.RimWorld.Biotech">Make_BabyFoodBulk</li>
    </recipes>
    <designationCategory>Production</designationCategory>
    <uiOrder>10001</uiOrder>
    <passability>PassThroughOnly</passability>
    <pathCost>35</pathCost>
    <hasInteractionCell>True</hasInteractionCell>
    <interactionCellOffset>(0,0,-1)</interactionCellOffset>
    <surfaceType>Item</surfaceType>
    <inspectorTabs>
      <li>ITab_Bills</li>
    </inspectorTabs>
    <building>
      <spawnedConceptLearnOpportunity>BillsTab</spawnedConceptLearnOpportunity>
      <paintable>false</paintable>
    </building>
    <comps>
	  <li Class="CompProperties_Refuelable">
        <fuelConsumptionRate>120.0</fuelConsumptionRate>
        <fuelCapacity>35.0</fuelCapacity>
        <fuelFilter>
          <thingDefs>
            <li>WoodLog</li>
          </thingDefs>
        </fuelFilter>
        <consumeFuelOnlyWhenUsed>true</consumeFuelOnlyWhenUsed>
        <showAllowAutoRefuelToggle>true</showAllowAutoRefuelToggle>
        <canEjectFuel>true</canEjectFuel>
      </li>
	  <li Class="CompProperties_HeatPusher">
        <compClass>CompHeatPusherPowered</compClass>
        <heatPerSecond>4</heatPerSecond>
      </li>
	  <li Class="CompProperties_Glower">
        <glowRadius>2</glowRadius>
        <glowColor>(252,187,113,0)</glowColor>
      </li>
    </comps>
    <placeWorkers>
      <li>PlaceWorker_PreventInteractionSpotOverlap</li>
    </placeWorkers>
    <researchPrerequisites>
      <li>GloomGitz_Basic</li>
    </researchPrerequisites>
