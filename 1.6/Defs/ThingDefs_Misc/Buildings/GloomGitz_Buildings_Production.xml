  <ThingDef ParentName="BenchBase">
    <defName>AOSGitz_Tailor</defName>
    <label>Grot Fabrik Table</label>
	<designatorDropdown>AOSgitz_Production</designatorDropdown>
    <description>A crude table with a pile of fabric scraps, a broken loom, and a sharp slitta to cut it into shape.</description>
    <thingClass>Building_WorkTable</thingClass>
    <graphicData>
      <texPath>Things/Building/Production/Gitz/Tailor/GloomspitzTailor</texPath>
      <graphicClass>Graphic_Multi</graphicClass>
      <drawSize>(3,2)</drawSize>
	  <shadowData>
        <volume>(1.5, 0.22, 0.47)</volume>
        <offset>(0, 0, 0.08)</offset>
      </shadowData>
      <shaderType>CutoutComplex</shaderType>
      <damageData>
        <cornerTL>Damage/Corner</cornerTL>
        <cornerTR>Damage/Corner</cornerTR>
        <cornerBL>Damage/Corner</cornerBL>
        <cornerBR>Damage/Corner</cornerBR>
      </damageData>
    </graphicData>
	<costList>
      <Steel>10</Steel>
	  <WoodLog>35</WoodLog>
    </costList>
    <castEdgeShadows>true</castEdgeShadows>
    <altitudeLayer>Building</altitudeLayer>
    <fillPercent>0.5</fillPercent>
    <useHitPoints>True</useHitPoints>
    <statBases>
      <WorkToBuild>1200</WorkToBuild>
      <MaxHitPoints>120</MaxHitPoints>
      <Flammability>1.5</Flammability>
      <WorkTableWorkSpeedFactor>0.45</WorkTableWorkSpeedFactor>
	  <Cleanliness>-1</Cleanliness>
    </statBases>
    <size>(2,1)</size>
    <designationCategory>Production</designationCategory>
    <uiOrder>10001</uiOrder>
    <passability>PassThroughOnly</passability>
    <pathCost>35</pathCost>
    <hasInteractionCell>True</hasInteractionCell>
    <interactionCellOffset>(0,0,-1)</interactionCellOffset>
    <surfaceType>Item</surfaceType>
    <inspectorTabs>
      <li>ITab_Bills</li>
    </inspectorTabs>
    <building>
      <spawnedConceptLearnOpportunity>BillsTab</spawnedConceptLearnOpportunity>
      <paintable>false</paintable>
      <workTableRoomRole>Workshop</workTableRoomRole>
      <workTableNotInRoomRoleFactor>0.95</workTableNotInRoomRoleFactor>
    </building>
    <comps>
    </comps>
    <placeWorkers>
      <li>PlaceWorker_PreventInteractionSpotOverlap</li>
    </placeWorkers>
    <researchPrerequisites>
      <li>GloomGitz_Basic</li>
    </researchPrerequisites>
  </ThingDef>

  <ThingDef ParentName="BenchBase">
