          <li>Root</li>
        </categories>
        <disallowedThingDefs>
          <li>Gold</li>
          <li>Silver</li>
          <li>Plasteel</li>
          <li>Jade</li>
          <li>Uranium</li>
          <li MayRequire="Ludeon.RimWorld.Anomaly">Bioferrite</li>
          <li MayRequire="Ludeon.RimWorld.Odyssey">Obsidian</li>
        </disallowedThingDefs>
      </defaultIngredientFilter>
    </recipeMaker>
    <tradeTags>
      <li>GloomGitzApparel</li>
    </tradeTags>
  </ThingDef>
  
  <ThingDef Name="ApparelGloomGitzSmithBase" ParentName="ApparelBase" Abstract="True">
