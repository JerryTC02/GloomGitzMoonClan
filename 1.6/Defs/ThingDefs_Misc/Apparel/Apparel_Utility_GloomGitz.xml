      </layers>
	  <tags Inherit="False">
       <li>MoonClan_MageUtilityElite</li>
      </tags>
      <developmentalStageFilter>Child, Adult</developmentalStageFilter>
    </apparel>
        <comps>
            <li Class="CVN_HandShield.CompProperties_HandheldShield">
				<weaponWeightLimit>3</weaponWeightLimit>
                <isDropWeaponIfOverweight>true</isDropWeaponIfOverweight>
                <isShieldStopFunctionIfOverweight>true</isShieldStopFunctionIfOverweight>
